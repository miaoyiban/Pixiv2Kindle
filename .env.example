# ── Application ────────────────────────────────────────
APP_NAME=pixiv2kindle
APP_ENV=dev
LOG_LEVEL=INFO

# ── Discord ────────────────────────────────────────────
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=
DISCORD_BOT_TOKEN=
ALLOWED_DISCORD_USER_ID=

# ── Pixiv ──────────────────────────────────────────────
PIXIV_REFRESH_TOKEN=

# ── Kindle / SMTP ──────────────────────────────────────
KINDLE_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# ── Translation (M3) ──────────────────────────────────
TRANSLATION_PROVIDER=noop
GEMINI_API_KEY=
OPENAI_API_KEY=
FAIL_ON_TRANSLATION_ERROR=false

# ── File handling ──────────────────────────────────────
TEMP_DIR=./tmp
KEEP_RECENT_EPUB_COUNT=0
MAX_EPUB_BYTES=50000000

# ── Internal API (Workers → Backend) ──────────────────
INTERNAL_API_TOKEN=
BACKEND_BASE_URL=

# ── Cloud Tasks (M2) ──────────────────────────────────
QUEUE_BACKEND=local
CLOUD_TASKS_PROJECT_ID=
CLOUD_TASKS_LOCATION=
CLOUD_TASKS_QUEUE_NAME=
CLOUD_TASKS_TASK_HANDLER_URL=

# ── Deadline ──────────────────────────────────────────
FOLLOWUP_SOFT_DEADLINE_SECONDS=720
FOLLOWUP_HARD_DEADLINE_SECONDS=900
