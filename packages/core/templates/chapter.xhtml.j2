<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="{{ language }}">
<head>
  <meta charset="utf-8" />
  <title>{{ title }}</title>
  <link rel="stylesheet" type="text/css" href="styles.css" />
</head>
<body>
  <h1>{{ title }}</h1>
  {% if author %}
  <p class="author">{{ author }}</p>
  {% endif %}

  {% for block in blocks %}
  {% if block.translated %}
  <div class="block">
    <p class="src">{{ block.source | e }}</p>
    <p class="dst">{{ block.translated | e }}</p>
  </div>
  {% else %}
  <p>{{ block.source | e }}</p>
  {% endif %}
  {% endfor %}
</body>
</html>
